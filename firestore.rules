rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Blog Posts
    match /blogPosts/{postId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }
    
    // Projects
    match /projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }
    
    // Services
    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }
    
    // Team Members
    match /team/{memberId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }
    
    // Testimonials
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }
    
    // Inquiries (public can create, only admin can read/update/delete)
    match /inquiries/{inquiryId} {
      allow read: if isAuthenticated();
      allow create: if true;
      allow update, delete: if isAuthenticated();
    }

    // Chat Sessions (public can create/update/read for real-time chat)
    match /chatSessions/{sessionId} {
      allow read: if true; // Public can read for real-time updates
      allow create: if true;
      allow update: if true; // Allow updates from widget
      allow delete: if isAuthenticated();
    }

    // Chatbot Config (admin only)
    match /chatbotConfig/{configId} {
      allow read: if true; // Public can read config
      allow create, update, delete: if isAuthenticated();
    }

    // Chatbot Q&A (public can read, admin can manage)
    match /chatbotQA/{qaId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }

    // Contact Submissions (public can create, only admin can read/update/delete)
    match /contactSubmissions/{submissionId} {
      allow read: if isAuthenticated();
      allow create: if true;
      allow update, delete: if isAuthenticated();
    }
    
    // Quote Requests (public can create, only admin can read/update/delete)
    match /quoteRequests/{quoteId} {
      allow read: if isAuthenticated();
      allow create: if true;
      allow update, delete: if isAuthenticated();
    }
    
    // Clients
    match /clients/{clientId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }
    
    // About
    match /about/{docId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }
    
    // FAQ
    match /faq/{faqId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }
    
    // Pages (Custom CMS Pages)
    match /pages/{pageId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }
    
    // Site Settings
    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }
  }
}
